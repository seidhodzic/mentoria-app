NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: override auth cookie/storage key (default sb-<project-ref>-auth-token from NEXT_PUBLIC_SUPABASE_URL)
# NEXT_PUBLIC_SUPABASE_AUTH_COOKIE_NAME=sb-your-project-ref-auth-token
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Regenerate types/supabase.ts: npm run gen:types — needs one of:
# SUPABASE_ACCESS_TOKEN (https://supabase.com/dashboard/account/tokens)
# DATABASE_URL (Project → Settings → Database → URI, include sslmode if required)
# Must match the port you run (e.g. 3001 if you use npm run dev:3001)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_NOTIFICATION_EMAIL=founder@mentoria.example
RESEND_API_KEY=optional-resend-api-key
# Optional: same random string in both vars hardens the signup notify Server Action against bots (see app/auth/actions.ts)
# SIGNUP_NOTIFY_SECRET=
# NEXT_PUBLIC_SIGNUP_NOTIFY_TOKEN=
STRIPE_SECRET_KEY=optional-stripe-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=optional-stripe-publishable
